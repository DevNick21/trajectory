# Trajectory — example environment file.
# Copy to .env and fill in the real values. .env is gitignored.

# ---- credentials (required) -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=12345:abc...
COMPANIES_HOUSE_API_KEY=...

# ---- dual-surface identity (required for the API) ------------------------
# Single-user demo: both surfaces resolve to the same user_profiles row
# keyed by this value. Set it to your numeric Telegram user id (the same
# value `update.effective_user.id` returns).
DEMO_USER_ID=

# ---- web surface (optional — defaults shown) -----------------------------
API_PORT=8000
# CORS allowlist for the FastAPI app. Strict — no wildcards.
WEB_ORIGIN=http://localhost:5173
# Public URL the bot points un-onboarded users at (Wave 10).
WEB_URL=http://localhost:5173

# ---- feature flags (default off) -----------------------------------------
# Sandboxed Managed Agents company investigator (PROCESS Entry 35).
ENABLE_MANAGED_COMPANY_INVESTIGATOR=false
# Multi-turn agentic CV tailor (PROCESS Entry 36).
ENABLE_AGENTIC_CV_TAILOR=false
# Telegram per-user rate limiting.
ENFORCE_RATE_LIMIT=false
