# Trajectory — example environment file.
# Copy to .env and fill in the real values. .env is gitignored.

# ---- credentials (required) -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=12345:abc...
COMPANIES_HOUSE_API_KEY=...

# ---- dual-surface identity (required for the API) ------------------------
# Single-user demo: both surfaces resolve to the same user_profiles row
# keyed by this value. Set it to your numeric Telegram user id (the same
# value `update.effective_user.id` returns).
DEMO_USER_ID=

# ---- web surface (optional — defaults shown) -----------------------------
API_PORT=8000
# CORS allowlist for the FastAPI app. Strict — no wildcards.
WEB_ORIGIN=http://localhost:5173
# Public URL the bot points un-onboarded users at (Wave 10).
WEB_URL=http://localhost:5173

# ---- feature flags --------------------------------------------------------
# Telegram per-user rate limiting.
ENFORCE_RATE_LIMIT=false

# Sandboxed Managed Agents company investigator (PROCESS Entry 35).
# High-fidelity Phase 1 research — sandboxed multi-step web fetches.
ENABLE_MANAGED_COMPANY_INVESTIGATOR=true

# Replace the no-op jobspy reviews path with the Managed Agents
# reviews_investigator session. Falls back to the legacy path on failure.
ENABLE_MANAGED_REVIEWS_INVESTIGATOR=true

# Money-no-object verdict ensemble — runs verdict twice, conservative-merges.
ENABLE_VERDICT_ENSEMBLE=true
# When the ensemble is on, swap slot 2 to verdict_deep_research (Web Search +
# Web Fetch live augmentation). No-op when ENABLE_VERDICT_ENSEMBLE=false.
ENABLE_VERDICT_ENSEMBLE_DEEP_RESEARCH=true

# ---- agentic + managed Phase 4 generators (PROCESS Entry 48) -------------
# Each wraps the in-process generator with Web Search + Web Fetch (and
# Code Execution for salary). Falls back to the in-process path on session
# failure — never takes the demo down.
#
# cover_letter live-fetches the company's careers / values pages targeted
# to THIS user's motivations.
ENABLE_MANAGED_COVER_LETTER=true
# likely_questions live-fetches actual reported interview experience
# (Glassdoor mirrors, Reddit, eng blogs) — quotes beat inferred categories.
ENABLE_MANAGED_LIKELY_QUESTIONS=true
# salary_strategist runs Code Execution for percentile / Monte Carlo math
# instead of prose-based numerical reasoning.
ENABLE_MANAGED_SALARY_STRATEGIST=true
# Multi-turn agentic CV tailor wrapped in a Managed Agents session.
# When False, draft_cv runs the in-process cv_tailor_agentic directly.
ENABLE_MANAGED_CV_TAILOR=true

# ---- queue + cost knobs (default off) -------------------------------------
# Route /api/queue/process through the Anthropic Batch API (50% discount,
# async). Currently a credential-ping; full per-step batching lands in a
# follow-up handle_forward_job refactor.
ENABLE_BATCH_QUEUE_RUNNER=false

# ---- multi-provider CV tailor (PROCESS Entry 44) --------------------------
# When True, /draft_cv routes to the LLM provider mapped from the job URL's
# ATS host (see ats_routing.ATS_TO_PROVIDER). Anthropic-routed URLs and
# unmapped hosts keep the existing Opus 4.7 path. Provider misconfig
# (missing API key) falls back to Anthropic — non-fatal.
ENABLE_MULTI_PROVIDER_CV_TAILOR=true
# Per-provider API keys. Only required if you actually flip the flag on
# AND your job URLs route through these providers.
OPENAI_API_KEY=
COHERE_API_KEY=
